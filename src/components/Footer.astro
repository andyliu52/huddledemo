---
const currentYear = new Date().getFullYear();

const serviceLinks = [
  { href: '/services/agricultural', label: 'Agricultural Buildings' },
  { href: '/services/commercial', label: 'Commercial Buildings' },
  { href: '/services/residential', label: 'Barndominiums' },
  { href: '/services/metal-roofing', label: 'Metal Roofing' },
  { href: '/services/churches', label: 'Church Buildings' },
];

const areaLinks = [
  { href: '/service-areas/canton-tx', label: 'Canton, TX' },
  { href: '/service-areas/tyler-tx', label: 'Tyler, TX' },
  { href: '/service-areas/athens-tx', label: 'Athens, TX' },
  { href: '/service-areas/terrell-tx', label: 'Terrell, TX' },
  { href: '/service-areas/greenville-tx', label: 'Greenville, TX' },
];

const companyLinks = [
  { href: '/about', label: 'About Us' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
  { href: '/quote', label: 'Get a Quote' },
];
---

<footer class="bg-charcoal-light border-t border-border">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
      <div>
        <a href="/" class="inline-block mb-4">
          <span class="text-xl font-extrabold tracking-tight">
            <span class="text-white">HUDDLE</span>
            <span class="text-burnt-orange"> STEEL</span>
          </span>
        </a>
        <p class="text-medium-gray text-sm leading-relaxed mb-4">
          Custom steel &amp; metal buildings in Canton, TX and throughout East Texas. DIY kits and turn-key construction.
        </p>
        <div class="space-y-2 text-sm">
          <a href="tel:9038656200" class="flex items-center gap-2 text-medium-gray hover:text-burnt-orange transition-colors">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (903) 865-6200
          </a>
          <a href="mailto:Tara@HuddleSteelBuildings.com" class="flex items-center gap-2 text-medium-gray hover:text-burnt-orange transition-colors">
            <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            Tara@HuddleSteelBuildings.com
          </a>
          <div class="flex items-start gap-2 text-medium-gray">
            <svg class="w-4 h-4 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            29866 State Hwy 64<br />Canton, TX 75103
          </div>
        </div>
      </div>

      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Services</h3>
        <ul class="space-y-2">
          {serviceLinks.map(link => (
            <li>
              <a href={link.href} class="text-medium-gray hover:text-burnt-orange text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Service Areas</h3>
        <ul class="space-y-2">
          {areaLinks.map(link => (
            <li>
              <a href={link.href} class="text-medium-gray hover:text-burnt-orange text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
          <li>
            <a href="/service-areas" class="text-burnt-orange hover:text-burnt-orange-light text-sm font-medium transition-colors">
              View All Areas →
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-4">Company</h3>
        <ul class="space-y-2">
          {companyLinks.map(link => (
            <li>
              <a href={link.href} class="text-medium-gray hover:text-burnt-orange text-sm transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-medium-gray text-sm">
        &copy; {currentYear} Huddle Steel Buildings. All rights reserved.
      </p>
      <p class="text-dark-gray text-xs">
        29866 State Hwy 64, Canton, TX 75103 &bull; (903) 865-6200
      </p>
    </div>
  </div>
</footer>
