---
interface Props {
  title: string;
  description: string;
  date: Date;
  slug: string;
  tags?: string[];
}

const { title, description, date, slug, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group bg-charcoal-light border border-border rounded-lg overflow-hidden hover:border-burnt-orange/50 transition-all duration-300">
  <div class="aspect-video bg-charcoal-lighter flex items-center justify-center">
    <svg class="w-12 h-12 text-dark-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" /></svg>
  </div>
  <div class="p-5">
    {tags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-3">
        {tags.slice(0, 2).map(tag => (
          <span class="text-xs font-medium uppercase tracking-wider text-burnt-orange bg-burnt-orange/10 px-2 py-0.5 rounded">
            {tag}
          </span>
        ))}
      </div>
    )}
    <h3 class="text-lg font-bold text-white mb-2 group-hover:text-burnt-orange transition-colors line-clamp-2">
      <a href={`/blog/${slug}/`}>{title}</a>
    </h3>
    <p class="text-medium-gray text-sm leading-relaxed line-clamp-3 mb-3">{description}</p>
    <time datetime={date.toISOString()} class="text-xs text-dark-gray">{formattedDate}</time>
  </div>
</article>
