---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
}

const { title, description, href, icon } = Astro.props;
---

<a href={href} class="group block bg-charcoal-light border border-border rounded-lg p-6 hover:border-burnt-orange/50 hover:bg-charcoal-lighter transition-all duration-300">
  <div class="w-12 h-12 bg-burnt-orange/10 rounded-lg flex items-center justify-center mb-4 group-hover:bg-burnt-orange/20 transition-colors">
    <span class="text-2xl" set:html={icon} />
  </div>
  <h3 class="text-lg font-bold text-white mb-2 group-hover:text-burnt-orange transition-colors">{title}</h3>
  <p class="text-medium-gray text-sm leading-relaxed">{description}</p>
  <span class="inline-flex items-center gap-1 mt-4 text-burnt-orange text-sm font-medium group-hover:gap-2 transition-all">
    Learn More
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
  </span>
</a>
