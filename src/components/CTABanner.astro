---
interface Props {
  headline?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
}

const {
  headline = 'Ready to Build?',
  description = 'Get a free, no-obligation quote on your custom steel building project. We serve Canton, TX and all of East Texas.',
  buttonText = 'Get Your Free Quote',
  buttonHref = '/quote',
} = Astro.props;
---

<section class="bg-gradient-to-r from-burnt-orange to-burnt-orange-dark py-16 lg:py-20">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
    <h2 class="text-3xl lg:text-4xl font-extrabold text-white mb-4">{headline}</h2>
    <p class="text-lg text-white/90 mb-8 max-w-2xl mx-auto">{description}</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href={buttonHref}
        class="inline-flex items-center px-8 py-3.5 bg-white text-burnt-orange font-bold rounded-md hover:bg-light-gray transition-colors text-lg"
      >
        {buttonText}
      </a>
      <a
        href="tel:9038656200"
        class="inline-flex items-center gap-2 px-8 py-3.5 border-2 border-white text-white font-bold rounded-md hover:bg-white/10 transition-colors text-lg"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
        (903) 865-6200
      </a>
    </div>
  </div>
</section>
