---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
---

<Layout
  title="Get a Free Quote | Metal Buildings | Huddle Steel Buildings | Canton, TX"
  description="Request a free, no-obligation quote on your metal building project from Huddle Steel Buildings. Barndominiums, agricultural buildings, commercial structures, metal roofing, and more."
>
  <section class="py-12 lg:py-20 bg-charcoal">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Get a Free Quote' }]} />

      <div class="mt-8 mb-12 text-center">
        <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-2">Free Estimate</p>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">
          Get Your <span class="text-burnt-orange">Free Quote</span>
        </h1>
        <p class="text-lg text-medium-gray max-w-2xl mx-auto">
          Tell us about your project and we'll provide a free, no-obligation quote. Most quotes are returned within 24-48 hours.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2">
          <div class="bg-charcoal-light border border-border rounded-lg p-6 lg:p-8">
            <QuoteForm />
          </div>
        </div>

        <div class="space-y-6">
          <div class="bg-charcoal-light border border-border rounded-lg p-6">
            <h2 class="text-lg font-bold text-white mb-3">What to Expect</h2>
            <ol class="space-y-4">
              {[
                { step: '1', title: 'Submit Your Details', desc: 'Fill out the form with your project information.' },
                { step: '2', title: 'We\'ll Review', desc: 'Our team reviews your needs and prepares an estimate.' },
                { step: '3', title: 'Receive Your Quote', desc: 'Get a detailed quote within 24-48 hours.' },
              ].map(item => (
                <li class="flex gap-3">
                  <span class="w-8 h-8 bg-burnt-orange/10 rounded-full flex items-center justify-center text-burnt-orange font-bold text-sm shrink-0">
                    {item.step}
                  </span>
                  <div>
                    <p class="text-white font-semibold text-sm">{item.title}</p>
                    <p class="text-dark-gray text-xs">{item.desc}</p>
                  </div>
                </li>
              ))}
            </ol>
          </div>

          <div class="bg-charcoal-light border border-border rounded-lg p-6">
            <h2 class="text-lg font-bold text-white mb-3">Prefer to Call?</h2>
            <a href="tel:9038656200" class="flex items-center gap-3 text-burnt-orange hover:text-burnt-orange-light font-semibold transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
              (903) 865-6200
            </a>
            <p class="text-dark-gray text-xs mt-2">Mon-Fri, 8am - 5pm</p>
          </div>

          <div class="bg-charcoal-light border border-border rounded-lg p-6">
            <h2 class="text-lg font-bold text-white mb-3">We Build</h2>
            <ul class="space-y-2 text-sm text-medium-gray">
              {['Agricultural Buildings', 'Commercial Buildings', 'Barndominiums', 'Metal Roofing', 'Church Buildings', 'Garages & Workshops'].map(s => (
                <li class="flex items-center gap-2">
                  <svg class="w-4 h-4 text-burnt-orange shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                  {s}
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
