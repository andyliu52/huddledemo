---

<Layout
  title="Project Gallery | Metal Building Photos | Huddle Steel Buildings"
  description="Browse photos of completed metal building projects by Huddle Steel Buildings. Agricultural buildings, commercial structures, barndominiums, metal roofing, and churches in East Texas."
>
  <section class="py-12 lg:py-20 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Gallery' }]} />

      <div class="mt-8 mb-12">
        <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-2">Our Work</p>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">
          Project <span class="text-burnt-orange">Gallery</span>
        </h1>
        <p class="text-lg text-medium-gray max-w-3xl">
          Browse our completed metal building projects across East Texas. From barndominiums to commercial warehouses, see the quality and craftsmanship of Huddle Steel Buildings.
        </p>
      </div>

      <div class="flex flex-wrap gap-2 mb-10">
        {categories.map(cat => (
          <button
            data-filter={cat.id}
            class:list={[
              'filter-btn px-4 py-2 rounded-full text-sm font-medium border transition-colors cursor-pointer',
              cat.id === 'all'
                ? 'bg-burnt-orange text-white border-burnt-orange'
                : 'text-medium-gray border-border hover:border-burnt-orange/50 hover:text-burnt-orange',
            ]}
          >
            {cat.label}
          </button>
        ))}
      </div>

      <div id="gallery-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {projects.map((project, i) => (
          <button
            data-category={project.category}
            data-index={i}
            class="gallery-item group relative aspect-[4/3] bg-charcoal-lighter rounded-lg overflow-hidden border border-border hover:border-burnt-orange/50 transition-all cursor-pointer text-left"
          >
            <img
              src={project.image}
              alt={project.alt}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-charcoal/80 via-transparent to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
            <div class="absolute top-3 right-3 w-8 h-8 bg-charcoal/60 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" /></svg>
            </div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <p class="text-white font-semibold">{project.title}</p>
              <p class="text-gray-300 text-sm">{project.location}</p>
              <p class="text-gray-400 text-xs mt-1">{project.desc}</p>
            </div>
          </button>
        ))}
      </div>
    </div>
  </section>

  <CTABanner />

  <!-- Lightbox Modal -->
  <div id="lightbox" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 backdrop-blur-sm">
    <button id="lightbox-close" class="absolute top-4 right-4 w-10 h-10 flex items-center justify-center text-white/80 hover:text-white transition-colors z-10 cursor-pointer">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center text-white/70 hover:text-white bg-white/10 hover:bg-white/20 rounded-full transition-colors z-10 cursor-pointer">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" /></svg>
    </button>
    <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center text-white/70 hover:text-white bg-white/10 hover:bg-white/20 rounded-full transition-colors z-10 cursor-pointer">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" /></svg>
    </button>
    <div class="max-w-5xl max-h-[85vh] mx-4">
      <img id="lightbox-img" src="" alt="" class="max-w-full max-h-[80vh] object-contain rounded-lg" />
      <div class="text-center mt-3">
        <p id="lightbox-title" class="text-white font-semibold text-lg"></p>
        <p id="lightbox-desc" class="text-gray-400 text-sm mt-1"></p>
      </div>
    </div>
  </div>
</Layout>

<script>
  const buttons = document.querySelectorAll('.filter-btn');
  const items = document.querySelectorAll('.gallery-item');

  buttons.forEach(btn => {
    btn.addEventListener('click', () => {
      const filter = (btn as HTMLElement).dataset.filter;

      buttons.forEach(b => {
        b.classList.remove('bg-burnt-orange', 'text-white', 'border-burnt-orange');
        b.classList.add('text-medium-gray', 'border-border');
      });
      btn.classList.add('bg-burnt-orange', 'text-white', 'border-burnt-orange');
      btn.classList.remove('text-medium-gray', 'border-border');

      items.forEach(item => {
        const el = item as HTMLElement;
        if (filter === 'all' || el.dataset.category === filter) {
          el.style.display = '';
        } else {
          el.style.display = 'none';
        }
      });
    });
  });

  const projects = Array.from(items).map(item => {
    const img = item.querySelector('img') as HTMLImageElement;
    const title = item.querySelector('p.text-white')?.textContent || '';
    const desc = item.querySelector('p.text-gray-400')?.textContent || '';
    return { src: img.src, alt: img.alt, title, desc, category: (item as HTMLElement).dataset.category };
  });

  const lightbox = document.getElementById('lightbox')!;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxTitle = document.getElementById('lightbox-title')!;
  const lightboxDesc = document.getElementById('lightbox-desc')!;
  let currentIndex = 0;
  let visibleIndices: number[] = [];

  function getVisibleIndices() {
    return Array.from(items)
      .map((item, i) => ({ item: item as HTMLElement, i }))
      .filter(({ item }) => item.style.display !== 'none')
      .map(({ i }) => i);
  }

  function showImage(index: number) {
    const p = projects[index];
    lightboxImg.src = p.src;
    lightboxImg.alt = p.alt;
    lightboxTitle.textContent = p.title;
    lightboxDesc.textContent = p.desc;
    currentIndex = index;
  }

  function openLightbox(index: number) {
    visibleIndices = getVisibleIndices();
    showImage(index);
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
    document.body.style.overflow = '';
  }

  function navigate(direction: number) {
    const pos = visibleIndices.indexOf(currentIndex);
    const next = (pos + direction + visibleIndices.length) % visibleIndices.length;
    showImage(visibleIndices[next]);
  }

  items.forEach((item) => {
    item.addEventListener('click', () => {
      const index = parseInt((item as HTMLElement).dataset.index || '0');
      openLightbox(index);
    });
  });

  document.getElementById('lightbox-close')!.addEventListener('click', closeLightbox);
  document.getElementById('lightbox-prev')!.addEventListener('click', () => navigate(-1));
  document.getElementById('lightbox-next')!.addEventListener('click', () => navigate(1));

  lightbox.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', (e) => {
    if (lightbox.classList.contains('hidden')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navigate(-1);
    if (e.key === 'ArrowRight') navigate(1);
  });
</script>
