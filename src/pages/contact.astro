---
import Layout from '../layouts/Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import QuoteForm from '../components/QuoteForm.astro';
---

<Layout
  title="Contact Us | Huddle Steel Buildings | Canton, TX"
  description="Contact Huddle Steel Buildings in Canton, TX. Call (903) 865-6200 or email us for a free quote on metal buildings, barndominiums, and metal roofing in East Texas."
>
  <section class="py-12 lg:py-20 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />

      <div class="mt-8 mb-12">
        <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-2">Get in Touch</p>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">
          Contact <span class="text-burnt-orange">Us</span>
        </h1>
        <p class="text-lg text-medium-gray max-w-3xl">
          Ready to start your metal building project? Give us a call, send an email, or fill out the form below. We're here to help.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <div>
          <div class="space-y-8">
            <div>
              <h2 class="text-xl font-bold text-white mb-4">Contact Information</h2>
              <div class="space-y-4">
                <a href="tel:9038656200" class="flex items-center gap-4 group">
                  <div class="w-12 h-12 bg-burnt-orange/10 rounded-lg flex items-center justify-center group-hover:bg-burnt-orange/20 transition-colors">
                    <svg class="w-6 h-6 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                  </div>
                  <div>
                    <p class="text-white font-semibold group-hover:text-burnt-orange transition-colors">(903) 865-6200</p>
                    <p class="text-dark-gray text-sm">Mon-Fri 8am - 5pm</p>
                  </div>
                </a>

                <a href="mailto:Tara@HuddleSteelBuildings.com" class="flex items-center gap-4 group">
                  <div class="w-12 h-12 bg-burnt-orange/10 rounded-lg flex items-center justify-center group-hover:bg-burnt-orange/20 transition-colors">
                    <svg class="w-6 h-6 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
                  </div>
                  <div>
                    <p class="text-white font-semibold group-hover:text-burnt-orange transition-colors">Tara@HuddleSteelBuildings.com</p>
                    <p class="text-dark-gray text-sm">Scott@HuddleSteelBuildings.com</p>
                  </div>
                </a>

                <div class="flex items-start gap-4">
                  <div class="w-12 h-12 bg-burnt-orange/10 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-6 h-6 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                  </div>
                  <div>
                    <p class="text-white font-semibold">29866 State Hwy 64</p>
                    <p class="text-medium-gray">Canton, TX 75103</p>
                  </div>
                </div>
              </div>
            </div>

            <div>
              <h2 class="text-xl font-bold text-white mb-4">Business Hours</h2>
              <div class="space-y-2 text-sm">
                <div class="flex justify-between text-medium-gray">
                  <span>Monday - Friday</span>
                  <span class="text-white">8:00 AM - 5:00 PM</span>
                </div>
                <div class="flex justify-between text-medium-gray">
                  <span>Saturday</span>
                  <span class="text-white">By Appointment</span>
                </div>
                <div class="flex justify-between text-medium-gray">
                  <span>Sunday</span>
                  <span class="text-dark-gray">Closed</span>
                </div>
              </div>
            </div>

            <div>
              <h2 class="text-xl font-bold text-white mb-4">Find Us</h2>
              <div class="aspect-video bg-charcoal-lighter rounded-lg border border-border overflow-hidden">
                <iframe
                  src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3358.0!2d-95.8633!3d32.5565!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMzLCsDMzJzIzLjQiTiA5NcKwNTEnNDcuOSJX!5e0!3m2!1sen!2sus!4v1709000000000"
                  width="100%"
                  height="100%"
                  style="border:0;"
                  allowfullscreen
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                  title="Huddle Steel Buildings location"
                ></iframe>
              </div>
            </div>
          </div>
        </div>

        <div>
          <div class="bg-charcoal-light border border-border rounded-lg p-6 lg:p-8">
            <h2 class="text-2xl font-bold text-white mb-2">Send Us a Message</h2>
            <p class="text-medium-gray mb-6">Fill out the form and we'll get back to you within one business day.</p>
            <QuoteForm compact />
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
