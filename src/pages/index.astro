---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import CTABanner from '../components/CTABanner.astro';

const services = [
  {
    title: 'Agricultural Buildings',
    description: 'Barns, hay storage, equipment shelters, and livestock facilities built to withstand Texas weather.',
    href: '/services/agricultural/',
    icon: '<svg class="w-6 h-6 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-4 0h4" /></svg>',
  },
  {
    title: 'Commercial Buildings',
    description: 'Warehouses, retail spaces, offices, and industrial facilities. Cost-effective and quick to erect.',
    href: '/services/commercial/',
    icon: '<svg class="w-6 h-6 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" /></svg>',
  },
  {
    title: 'Barndominiums',
    description: 'The perfect blend of rustic charm and modern living. Custom residential metal buildings with endless possibilities.',
    href: '/services/residential/',
    icon: '<svg class="w-6 h-6 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z" /></svg>',
  },
  {
    title: 'Metal Roofing',
    description: 'Durable, energy-efficient metal roofing for new construction and re-roofing projects across East Texas.',
    href: '/services/metal-roofing/',
    icon: '<svg class="w-6 h-6 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6z" /></svg>',
  },
  {
    title: 'Church Buildings',
    description: 'Custom-designed steel church buildings that provide spacious, open worship spaces at a fraction of traditional cost.',
    href: '/services/churches/',
    icon: '<svg class="w-6 h-6 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" /></svg>',
  },
  {
    title: 'Garages & Workshops',
    description: 'From single-car garages to full workshops. Steel buildings that protect your vehicles and tools.',
    href: '/services/commercial/',
    icon: '<svg class="w-6 h-6 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
];

const trustPoints = [
  {
    title: 'Local & Trusted',
    description: 'Family-owned business based in Canton, TX serving East Texas communities for years.',
    icon: '<svg class="w-8 h-8 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    title: 'DIY or Turn-Key',
    description: 'Choose a do-it-yourself kit or full turn-key construction — we handle it your way.',
    icon: '<svg class="w-8 h-8 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>',
  },
  {
    title: 'Competitive Pricing',
    description: 'High-quality steel buildings at prices that make sense. Free quotes with no obligation.',
    icon: '<svg class="w-8 h-8 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>',
  },
  {
    title: 'Built to Last',
    description: 'Premium steel construction engineered for Texas weather — wind, rain, and heat.',
    icon: '<svg class="w-8 h-8 text-burnt-orange" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>',
  },
];

const testimonials = [
  {
    quote: 'Huddle Steel Buildings made the whole process easy. From design to completion, they were professional and the building quality is outstanding.',
    author: 'Mike R.',
    location: 'Tyler, TX',
    project: 'Agricultural Building',
  },
  {
    quote: 'We got our barndominium built for a fraction of what traditional construction would have cost. Couldn\'t be happier with the result.',
    author: 'Sarah & Tom K.',
    location: 'Athens, TX',
    project: 'Barndominium',
  },
  {
    quote: 'Great folks to work with. The metal roofing they installed has held up perfectly through multiple storm seasons. Highly recommend.',
    author: 'David L.',
    location: 'Canton, TX',
    project: 'Metal Roofing',
  },
];
---

<Layout title="Huddle Steel Buildings | Custom Metal Buildings in Canton, TX & East Texas">
  <!-- Hero -->
  <section class="relative bg-charcoal overflow-hidden min-h-[600px] lg:min-h-[700px] flex items-center">
    <img
      src="/images/gallery/two-story-barndominium-exterior.jpg"
      alt="Two-story steel barndominium built by Huddle Steel Buildings in East Texas"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-gradient-to-r from-charcoal/90 via-charcoal/75 to-charcoal/30"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32">
      <div class="max-w-3xl">
        <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-4">Canton, TX &bull; Serving East Texas</p>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold text-white leading-tight mb-6">
          Custom <span class="text-burnt-orange">Steel Buildings</span> Built for Texas
        </h1>
        <p class="text-lg lg:text-xl text-medium-gray leading-relaxed mb-8 max-w-2xl">
          From barndominiums to commercial warehouses, Huddle Steel Buildings delivers quality metal construction with both DIY kits and full turn-key service throughout East Texas.
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a
            href="/quote/"
            class="inline-flex items-center justify-center px-8 py-3.5 bg-burnt-orange hover:bg-burnt-orange-dark text-white font-bold rounded-md transition-colors text-lg"
          >
            Get a Free Quote
          </a>
          <a
            href="/services/"
            class="inline-flex items-center justify-center px-8 py-3.5 border-2 border-border text-white font-semibold rounded-md hover:border-burnt-orange hover:text-burnt-orange transition-colors text-lg"
          >
            Our Services
          </a>
        </div>
        <div class="flex items-center gap-6 mt-10 text-sm text-medium-gray">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            Free Estimates
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            DIY & Turn-Key
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
            Locally Owned
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section class="py-16 lg:py-24 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-2">What We Build</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-white">Our <span class="text-burnt-orange">Services</span></h2>
        <p class="mt-4 text-medium-gray text-lg max-w-2xl mx-auto">
          Whether you need an agricultural barn, a commercial warehouse, or your dream barndominium, we've got you covered.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map(service => (
          <ServiceCard {...service} />
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Huddle -->
  <section class="py-16 lg:py-24 bg-charcoal-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-2">Why Choose Us</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-white">The Huddle <span class="text-burnt-orange">Difference</span></h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
        {trustPoints.map(point => (
          <div class="text-center">
            <div class="w-16 h-16 bg-burnt-orange/10 rounded-full flex items-center justify-center mx-auto mb-4">
              <span set:html={point.icon} />
            </div>
            <h3 class="text-lg font-bold text-white mb-2">{point.title}</h3>
            <p class="text-medium-gray text-sm leading-relaxed">{point.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gallery Preview -->
  <section class="py-16 lg:py-24 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-2">Our Work</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-white">Recent <span class="text-burnt-orange">Projects</span></h2>
        <p class="mt-4 text-medium-gray text-lg max-w-2xl mx-auto">
          See some of our completed metal building projects across East Texas.
        </p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { label: 'Two-Story Barndominium', location: 'East Texas', image: '/images/gallery/two-story-barndominium-exterior.jpg', alt: 'Two-story gray barndominium with wraparound porch' },
          { label: 'Modern Barndominium', location: 'East Texas', image: '/images/gallery/modern-barndominium-black-tan-exterior.jpg', alt: 'Modern black and tan barndominium with covered patio' },
          { label: 'Large Workshop with Bifold Door', location: 'East Texas', image: '/images/gallery/large-workshop-hydraulic-door-open.jpg', alt: 'Large steel workshop with hydraulic bifold door open' },
        ].map(project => (
          <a href="/gallery/" class="group relative aspect-[4/3] bg-charcoal-lighter rounded-lg overflow-hidden border border-border hover:border-burnt-orange/50 transition-all block">
            <img
              src={project.image}
              alt={project.alt}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-300 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-charcoal/80 via-transparent to-transparent"></div>
            <div class="absolute bottom-0 left-0 right-0 p-4">
              <p class="text-white font-semibold">{project.label}</p>
              <p class="text-medium-gray text-sm">{project.location}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/gallery/" class="inline-flex items-center gap-2 text-burnt-orange font-semibold hover:text-burnt-orange-light transition-colors">
          View Full Gallery
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="py-16 lg:py-24 bg-charcoal-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-2">Testimonials</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-white">What Our <span class="text-burnt-orange">Clients</span> Say</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {testimonials.map(t => (
          <div class="bg-charcoal border border-border rounded-lg p-6">
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map(() => (
                <svg class="w-5 h-5 text-burnt-orange" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              ))}
            </div>
            <blockquote class="text-medium-gray leading-relaxed mb-4">"{t.quote}"</blockquote>
            <div>
              <p class="text-white font-semibold text-sm">{t.author}</p>
              <p class="text-dark-gray text-xs">{t.location} &bull; {t.project}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner />

  <!-- Service Areas Preview -->
  <section class="py-16 lg:py-24 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-2">Service Areas</p>
        <h2 class="text-3xl lg:text-4xl font-extrabold text-white">Serving <span class="text-burnt-orange">East Texas</span></h2>
        <p class="mt-4 text-medium-gray text-lg max-w-2xl mx-auto">
          Based in Canton, TX, we proudly serve communities within 60 miles including Tyler, Athens, Terrell, and more.
        </p>
      </div>
      <div class="flex flex-wrap justify-center gap-3">
        {[
          'Canton', 'Tyler', 'Athens', 'Terrell', 'Greenville', 'Mineola',
          'Emory', 'Rockwall', 'Forney', 'Gun Barrel City', 'Wills Point',
          'Kaufman', 'Lindale', 'Sulphur Springs', 'Grand Saline',
        ].map(city => (
          <a
            href={`/service-areas/${city.toLowerCase().replace(/\s+/g, '-')}-tx/`}
            class="px-4 py-2 bg-charcoal-light border border-border rounded-full text-sm text-medium-gray hover:text-burnt-orange hover:border-burnt-orange/50 transition-colors"
          >
            {city}, TX
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/service-areas/" class="inline-flex items-center gap-2 text-burnt-orange font-semibold hover:text-burnt-orange-light transition-colors">
          View All Service Areas
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
