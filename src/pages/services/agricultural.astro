---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABanner from '../../components/CTABanner.astro';

const faqs = [
  {
    question: 'What types of agricultural buildings do you construct?',
    answer: 'We build barns, hay storage buildings, equipment shelters, livestock facilities, riding arenas, milking parlors, and more. Each building is custom-designed to fit your specific farming or ranching operation.',
  },
  {
    question: 'How long does it take to build an agricultural steel building?',
    answer: 'Depending on the size and complexity, most agricultural buildings can be completed in 4-12 weeks from order to final construction. DIY kits can be erected even faster.',
  },
  {
    question: 'Can I get a DIY kit for my agricultural building?',
    answer: 'Absolutely. We offer complete DIY building kits with detailed instructions, pre-cut steel panels, and all necessary hardware. Many farmers and ranchers prefer this option to save on labor costs.',
  },
  {
    question: 'Are steel agricultural buildings better than traditional pole barns?',
    answer: 'Steel buildings offer superior durability, lower maintenance, better pest resistance, and longer lifespans compared to wood pole barns. They also offer clear-span interiors without support columns, maximizing usable space.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(faq => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: { '@type': 'Answer', text: faq.answer },
  })),
};
---

<Layout
  title="Agricultural Steel Buildings | Barns & Farm Buildings | Huddle Steel Buildings"
  description="Custom agricultural steel buildings in Canton, TX and East Texas. Barns, hay storage, equipment shelters, livestock facilities, and riding arenas. Free quotes available."
  schema={faqSchema}
>
  <section class="py-12 lg:py-20 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Services', href: '/services' }, { label: 'Agricultural Buildings' }]} />

      <div class="mt-8 lg:grid lg:grid-cols-2 lg:gap-16 lg:items-start">
        <div>
          <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-2">Agricultural</p>
          <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-6">
            Steel <span class="text-burnt-orange">Agricultural</span> Buildings
          </h1>
          <p class="text-lg text-medium-gray leading-relaxed mb-6">
            Protect your livestock, equipment, and harvest with a custom steel agricultural building from Huddle Steel Buildings. Our farm structures are engineered for East Texas weather and built to last for decades.
          </p>
          <ul class="space-y-3 mb-8">
            {['Barns & Hay Storage', 'Equipment & Machinery Shelters', 'Livestock Facilities', 'Riding Arenas & Stables', 'Dairy & Milking Parlors', 'Crop Storage Buildings'].map(item => (
              <li class="flex items-center gap-3 text-medium-gray">
                <svg class="w-5 h-5 text-burnt-orange shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" /></svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="/quote/" class="inline-flex items-center px-8 py-3.5 bg-burnt-orange hover:bg-burnt-orange-dark text-white font-bold rounded-md transition-colors text-lg">
            Get a Free Quote
          </a>
        </div>

        <div class="mt-10 lg:mt-0 space-y-6">
          <div class="aspect-[4/3] bg-charcoal-lighter rounded-lg border border-border flex items-center justify-center">
            <div class="text-center">
              <svg class="w-16 h-16 text-dark-gray mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg>
              <p class="text-dark-gray text-sm">Project photos coming soon</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-charcoal-light">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white mb-4">Why Steel for <span class="text-burnt-orange">Agriculture</span>?</h2>
      <p class="text-medium-gray text-lg max-w-3xl mb-12">
        Steel buildings have become the preferred choice for Texas farmers and ranchers. Here's why.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Clear-Span Interiors', desc: 'No interior support columns means maximum usable space for equipment, livestock, and storage.' },
          { title: 'Weather Resistant', desc: 'Engineered to withstand high winds, heavy rain, and the extreme Texas heat without deteriorating.' },
          { title: 'Low Maintenance', desc: 'Unlike wood structures, steel buildings resist termites, rot, and warping. Minimal upkeep required.' },
          { title: 'Quick Construction', desc: 'Pre-engineered components mean faster build times so you can get back to farming sooner.' },
          { title: 'Cost-Effective', desc: 'Lower construction and maintenance costs compared to traditional building methods. Built to last decades.' },
          { title: 'Customizable', desc: 'Design your building with the exact dimensions, doors, ventilation, and features your operation needs.' },
        ].map(item => (
          <div class="bg-charcoal border border-border rounded-lg p-6">
            <h3 class="text-lg font-bold text-white mb-2">{item.title}</h3>
            <p class="text-medium-gray text-sm leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24 bg-charcoal">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-extrabold text-white mb-8">Frequently Asked <span class="text-burnt-orange">Questions</span></h2>
      <div class="space-y-6">
        {faqs.map(faq => (
          <div class="border-b border-border pb-6">
            <h3 class="text-lg font-semibold text-white mb-2">{faq.question}</h3>
            <p class="text-medium-gray leading-relaxed">{faq.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CTABanner headline="Need an Agricultural Building?" description="Get a free quote on your farm or ranch building project. We serve Canton, TX and all of East Texas." />
</Layout>
