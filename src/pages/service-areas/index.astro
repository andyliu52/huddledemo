---
import Layout from '../../layouts/Layout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import CTABanner from '../../components/CTABanner.astro';
import { serviceAreas, counties } from '../../data/service-areas';

const areasByCounty = counties.map(county => ({
  county,
  cities: serviceAreas.filter(a => a.county + ' County' === county || county.startsWith(a.county)),
}));
---

<Layout
  title="Service Areas | Metal Buildings Near Me | Huddle Steel Buildings | Canton, TX"
  description="Huddle Steel Buildings serves Canton, TX and all of East Texas within 60 miles. Tyler, Athens, Terrell, Greenville, Mineola, and more. Free quotes on metal buildings."
>
  <section class="py-12 lg:py-20 bg-charcoal">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[{ label: 'Home', href: '/' }, { label: 'Service Areas' }]} />

      <div class="mt-8 mb-12">
        <p class="text-burnt-orange font-semibold uppercase tracking-wider text-sm mb-2">Where We Work</p>
        <h1 class="text-4xl lg:text-5xl font-extrabold text-white mb-4">
          Our <span class="text-burnt-orange">Service Areas</span>
        </h1>
        <p class="text-lg text-medium-gray max-w-3xl">
          Based in Canton, TX, Huddle Steel Buildings proudly serves communities within 60 miles. We build custom metal buildings, barndominiums, and provide metal roofing services throughout East Texas.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-12">
        {counties.map(county => {
          const cities = serviceAreas.filter(a => county.includes(a.county));
          return (
            <div class="bg-charcoal-light border border-border rounded-lg p-6">
              <h2 class="text-xl font-bold text-white mb-4">{county}</h2>
              <ul class="space-y-2">
                {cities.map(city => (
                  <li>
                    <a
                      href={`/service-areas/${city.slug}`}
                      class="flex items-center justify-between text-medium-gray hover:text-burnt-orange transition-colors"
                    >
                      <span>{city.city}, TX</span>
                      <span class="text-xs text-dark-gray">{city.distance}</span>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          );
        })}
      </div>

      <div class="bg-charcoal-light border border-border rounded-lg p-8 text-center">
        <h2 class="text-2xl font-bold text-white mb-3">Don't See Your City?</h2>
        <p class="text-medium-gray mb-6 max-w-xl mx-auto">
          We may still serve your area. Give us a call or request a quote and we'll let you know if we can help with your project.
        </p>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/quote" class="inline-flex items-center px-6 py-3 bg-burnt-orange hover:bg-burnt-orange-dark text-white font-bold rounded-md transition-colors">
            Request a Quote
          </a>
          <a href="tel:9038656200" class="inline-flex items-center gap-2 text-burnt-orange hover:text-burnt-orange-light font-semibold transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
            (903) 865-6200
          </a>
        </div>
      </div>
    </div>
  </section>

  <CTABanner />
</Layout>
