---
import Layout from './Layout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import CTABanner from '../components/CTABanner.astro';

interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  author: string;
  slug: string;
}

const { title, description, date, tags, author, slug } = Astro.props;

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const blogPostSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: date.toISOString(),
  author: {
    '@type': 'Organization',
    name: author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Huddle Steel Buildings',
    url: 'https://www.huddlesteelbuildings.com',
  },
  mainEntityOfPage: `https://www.huddlesteelbuildings.com/blog/${slug}`,
};
---

<Layout title={`${title} | Huddle Steel Buildings Blog`} description={description} schema={blogPostSchema}>
  <article class="py-12 lg:py-20 bg-charcoal">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <Breadcrumbs items={[
        { label: 'Home', href: '/' },
        { label: 'Blog', href: '/blog/' },
        { label: title },
      ]} />

      <header class="mt-8 mb-10">
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mb-4">
            {tags.map(tag => (
              <span class="text-xs font-medium uppercase tracking-wider text-burnt-orange bg-burnt-orange/10 px-3 py-1 rounded-full">
                {tag}
              </span>
            ))}
          </div>
        )}
        <h1 class="text-3xl lg:text-4xl font-extrabold text-white leading-tight mb-4">{title}</h1>
        <div class="flex items-center gap-4 text-sm text-medium-gray">
          <span>{author}</span>
          <span>&bull;</span>
          <time datetime={date.toISOString()}>{formattedDate}</time>
        </div>
      </header>

      <div class="prose max-w-none">
        <slot />
      </div>

      <div class="mt-12 pt-8 border-t border-border">
        <div class="bg-charcoal-light border border-border rounded-lg p-6 text-center">
          <h2 class="text-xl font-bold text-white mb-2">Need a Metal Building?</h2>
          <p class="text-medium-gray mb-4">Get a free, no-obligation quote from Huddle Steel Buildings.</p>
          <a href="/quote/" class="inline-flex items-center px-6 py-3 bg-burnt-orange hover:bg-burnt-orange-dark text-white font-bold rounded-md transition-colors">
            Request a Free Quote
          </a>
        </div>
      </div>
    </div>
  </article>

  <CTABanner />
</Layout>
